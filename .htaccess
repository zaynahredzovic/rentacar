<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # If the requested file/folder exists, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Redirect to public folder for assets, otherwise to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Protect sensitive files
<Files .env>
    Order Allow,Deny
    Deny from all
</Files>